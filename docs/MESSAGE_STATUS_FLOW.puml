@startuml
title Family Messenger — message status flow and where "new" may disappear

skinparam shadowing false
skinparam participantPadding 20
skinparam boxPadding 10
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

actor "User" as User
participant "SyncEngine" as SE
participant "FamilyMessengerApiClient" as API #A7D8FF
participant "MessagesRepository" as MR
database "LocalDatabase" as DB
participant "AppViewModel" as VM
participant "UI (Compose)" as UI

== Incremental sync ==

SE -> MR : syncCursor()
activate SE
activate MR
MR -> DB : snapshot().syncState.sinceId
activate DB
DB --> MR : sinceId
deactivate DB
MR --> SE : sinceId
deactivate MR

SE -> API : sync(sinceId)
activate API #A7D8FF
API --> SE : SyncPayload(messages, receipts,\nevents, nextSinceId)
deactivate API

== Tick application ==

SE -> MR : flushPendingMessages()
activate MR
MR -> DB : snapshot().pendingMessages
activate DB
DB --> MR : pending[]
deactivate DB

loop for each pending message
  MR -> API : sendMessage(request)
  activate API #A7D8FF
  API --> MR : MessagePayload(status = SENT)
  deactivate API
  MR -> DB : upsert(server payload)\nremove pending item
  activate DB
  deactivate DB
end
deactivate MR

SE -> MR : applyTick(contacts, payload)
activate MR
MR -> DB : update(snapshot)
activate DB
note right of MR
  Order inside applyTick():
  1. mergePayloads(payload.messages)
  2. applyReceipts(payload.receipts)
  3. appendEvents(payload.events)
  4. syncState.sinceId = payload.nextSinceId
end note
deactivate DB
deactivate MR

SE -> MR : markDelivered(incomingMessageIds)
activate MR
alt incoming ids not empty
  MR -> API : markDelivered(messageIds)
  activate API #A7D8FF
  API --> MR : AckResponse
  deactivate API
  MR -> DB : advanceStatuses(messageIds, DELIVERED)
  activate DB
  deactivate DB
end
deactivate MR
deactivate SE

DB --> VM : snapshots StateFlow
activate VM
VM -> VM : recompute unreadCounts\nfor incoming messages\nstatus != READ
VM --> UI : AppUiState
activate UI
UI -> UI : recompose
deactivate UI
deactivate VM

== New incoming message while chat is already open ==

note over VM
  Hot path:
  if screen == CHAT
  and selectedContactId != null
  and unreadCounts[selectedContactId] > 0
  then VM immediately calls markConversationRead()
end note

alt selected chat is open and unread count became > 0
  VM -> MR : markConversationRead(contactId)
  MR -> DB : snapshot().messages\nfilter incoming messageIds
  DB --> MR : messageIds

  alt messageIds not empty
    MR -> API : markRead(messageIds)
    API --> MR : AckResponse
  end

  MR -> DB : advanceStatuses(messageIds, READ)\nlastReadAtByChat[contactId] = now
  DB --> VM : snapshots StateFlow
  VM -> VM : unreadCounts[selectedId] = 0
  VM --> UI : AppUiState
  UI -> UI : badge/new state disappears
end

== Opening a chat also advances status ==

User -> VM : openChat(contact)
activate User
activate VM
VM -> MR : conversation(contactId)
activate MR
MR -> DB : snapshot().messages
activate DB
DB --> MR : conversation messages
deactivate DB
MR --> VM : messages
deactivate MR
VM --> UI : show conversation
activate UI
deactivate UI

VM -> MR : markConversationRead(contactId)
activate MR
MR -> API : markRead(messageIds)
activate API #A7D8FF
API --> MR : AckResponse
deactivate API
MR -> DB : advanceStatuses(messageIds, READ)\nlastReadAtByChat[contactId] = now
activate DB
deactivate DB
deactivate MR
deactivate VM
deactivate User

note over DB,UI
  Practical consequence:
  after sync a new incoming message is first advanced to DELIVERED
  and only later becomes READ when the chat is opened
  or when auto-read fires for the visible chat.
end note

@enduml
